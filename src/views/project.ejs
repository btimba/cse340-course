<%- include('partials/header') %>

<main class="project-detail-page">
    <section class="project-hero">
        <span class="eyebrow">Community Service</span>
        <h1><%= project.title %></h1>
        <p class="page-intro"><%= project.description %></p>
    </section>

    <section class="project-details">
        <div class="project-info">
            <h2>Project Information</h2>
            <ul>
                <li><strong>Date:</strong> <%= new Date(project.project_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></li>
                <li><strong>Organization:</strong> <%= project.organization_name %></li>
                <li><strong>Location:</strong> <%= project.location %></li>
            </ul>
        </div>

        <div class="project-description">
            <h2>Project Description</h2>
            <p><%= project.long_description %></p>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
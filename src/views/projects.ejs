 <%- include('partials/header') %>

<main class="projects-page">
    <section class="projects-hero">
        <span class="eyebrow">Community Service</span>
        <h1><%= title %></h1>
        <p class="page-intro">Browse upcoming service projects and discover local volunteer opportunities with our partner organizations.</p>
    </section>

    <section class="projects-grid">
        <% if (projects.length) { %>
            <ul class="project-list">
                <% projects.forEach(project => { %>
                    <li class="project-item">
                        <div class="project-card-inner">
                            <div class="project-main">
                                <a href="/projects/<%= project.project_id %>">
                                    <h2><%= project.title %></h2>
                                </a>
                                <p class="project-meta">
                                    <span class="project-org"><%= project.organization_name %></span>
                                    <span class="project-date">
                                        <%= new Date(project.project_date).toLocaleDateString('en-US', {
                                            year: 'numeric',
                                            month: 'long',
                                            day: 'numeric'
                                        }) %>
                                    </span>
                                </p>
                                <% if (project.categories?.length) { %>
                                    <div class="project-categories">
                                        <strong>Categories:</strong>
                                        <% project.categories.forEach(category => { %>
                                            <a
                                                class="category-tag"
                                                href="/category/<%= category.category_id %>">
                                                <%= category.name %>
                                            </a>
                                        <% }) %>
                                    </div>
                                <% } %>
                            </div>
                            <span class="project-chevron" aria-hidden="true">→</span>
                        </div>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <div class="empty-state">
                <p>No upcoming service projects are currently available. Check back soon for new opportunities.</p>
            </div>
        <% } %>
    </section>
</main>
    <%- include('partials/footer') %>

<%- include('partials/header') %>

<main class="organization-details">

    <a href="/organizations">← Back to Organizations</a>

    <h1><%= organization.name %></h1>

    <img
        class="organization-detail-logo"
        src="/images/<%= organization.logo_filename %>"
        alt="<%= organization.name %> logo"
    >

    <p><%= organization.description %></p>

    <p>
        <strong>Email:</strong>
        <%= organization.contact_email %>
    </p>

    <section>
        <h2>Service Projects</h2>
        <% if (projects.length) { %>
            <ul>
                <% projects.forEach(project => { %>
                    <li>
                        <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                        <span> — <%= new Date(project.project_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>No service projects are currently listed for this organization.</p>
        <% } %>
    </section>

</main>

<%- include('partials/footer') %>